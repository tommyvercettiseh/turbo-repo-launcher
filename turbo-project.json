{
  "schema_version": 1,
  "name": "Turbo Repo Hub",
  "slug": "turbo-repo-launcher",
  "version": "0.5.0",
  "description": "Eenvoudige centrale hub voor het herkennen, bijwerken, starten en publiceren van lokale en gekoppelde GitHub-projecten.",
  "preview": "docs/previews/latest.svg",
  "tags": ["Python", "FastAPI", "GitHub", "Automation"],
  "runtime": {
    "type": "python-fastapi",
    "port": 8787,
    "start_command": "Start Turbo Repo Launcher.bat",
    "health_path": "/health"
  },
  "testing": {
    "command": "python -m pytest -q"
  },
  "security": {
    "public_api": false,
    "rate_limiting": false,
    "max_request_seconds": 300
  },
  "data": {
    "mode": "local-json",
    "provider": null
  },
  "deployment": {
    "enabled": false,
    "provider": null,
    "public_url": null
  },
  "integrations": {
    "home_assistant": false,
    "mqtt": false,
    "github": true
  }
}